# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# Telegram notifications (optional)
# Create a bot with @BotFather on Telegram, get the token
# Then send /start to your bot and get your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Check interval in hours
CHECK_INTERVAL_HOURS=4

# Database
DATABASE_URL=sqlite:///prices.db
